# ── Database ──────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/trackr"

# ── NextAuth ──────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
