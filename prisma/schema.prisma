// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth ──────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // hashed, null for OAuth users
  currency      String    @default("INR")
  locale        String    @default("en-IN")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  transactions  Transaction[]
  categories    Category[]
  budgets       Budget[]
  goals         Goal[]
  loans         Loan[]
  splits        Split[]
  recurringRules RecurringRule[]
  contacts      Contact[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Transactions ──────────────────────────────────

enum TransactionType {
  INCOME
  EXPENSE
}

model Transaction {
  id            String          @id @default(cuid())
  userId        String
  type          TransactionType
  amount        Decimal         @db.Decimal(12, 2)
  currency      String          @default("INR")
  description   String
  notes         String?
  date          DateTime
  categoryId    String?
  recurringRuleId String?
  attachmentUrl String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category?       @relation(fields: [categoryId], references: [id])
  recurringRule RecurringRule?  @relation(fields: [recurringRuleId], references: [id])

  @@index([userId, date])
  @@index([userId, type])
  @@map("transactions")
}

// ── Categories ────────────────────────────────────

model Category {
  id           String        @id @default(cuid())
  userId       String
  name         String
  icon         String        @default("circle")
  color        String        @default("#3A7BD5")
  type         TransactionType
  isDefault    Boolean       @default(false)
  createdAt    DateTime      @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, name, type])
  @@map("categories")
}

// ── Budgets ───────────────────────────────────────

model Budget {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  amount     Decimal  @db.Decimal(12, 2)
  month      Int      // 1–12
  year       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month, year])
  @@map("budgets")
}

// ── Goals ─────────────────────────────────────────

model Goal {
  id           String   @id @default(cuid())
  userId       String
  name         String
  targetAmount Decimal  @db.Decimal(12, 2)
  savedAmount  Decimal  @db.Decimal(12, 2) @default(0)
  deadline     DateTime?
  icon         String   @default("target")
  color        String   @default("#3A7BD5")
  isCompleted  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

// ── Loans (lending & borrowing) ───────────────────

enum LoanType {
  LENT      // I gave money to someone
  BORROWED  // I owe money to someone
}

enum LoanStatus {
  ACTIVE
  PARTIALLY_PAID
  SETTLED
  OVERDUE
}

model Loan {
  id          String     @id @default(cuid())
  userId      String
  contactId   String
  type        LoanType
  amount      Decimal    @db.Decimal(12, 2)
  paidAmount  Decimal    @db.Decimal(12, 2) @default(0)
  currency    String     @default("INR")
  description String
  notes       String?
  dueDate     DateTime?
  status      LoanStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact     Contact    @relation(fields: [contactId], references: [id])
  repayments  LoanRepayment[]

  @@index([userId, status])
  @@map("loans")
}

model LoanRepayment {
  id        String   @id @default(cuid())
  loanId    String
  amount    Decimal  @db.Decimal(12, 2)
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())

  loan      Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@map("loan_repayments")
}

// ── Contacts ──────────────────────────────────────

model Contact {
  id        String   @id @default(cuid())
  userId    String
  name      String
  phone     String?
  email     String?
  avatar    String?
  notes     String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loans     Loan[]
  splitMembers SplitMember[]

  @@unique([userId, name])
  @@map("contacts")
}

// ── Splits ────────────────────────────────────────

enum SplitStatus {
  UNSETTLED
  PARTIALLY_SETTLED
  SETTLED
}

model Split {
  id          String      @id @default(cuid())
  userId      String
  title       String
  totalAmount Decimal     @db.Decimal(12, 2)
  currency    String      @default("INR")
  date        DateTime
  notes       String?
  status      SplitStatus @default(UNSETTLED)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  members     SplitMember[]

  @@map("splits")
}

model SplitMember {
  id          String  @id @default(cuid())
  splitId     String
  contactId   String
  shareAmount Decimal @db.Decimal(12, 2)
  isPaid      Boolean @default(false)
  paidAt      DateTime?

  split       Split   @relation(fields: [splitId], references: [id], onDelete: Cascade)
  contact     Contact @relation(fields: [contactId], references: [id])

  @@unique([splitId, contactId])
  @@map("split_members")
}

// ── Recurring Rules ───────────────────────────────

enum RecurringFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model RecurringRule {
  id          String             @id @default(cuid())
  userId      String
  type        TransactionType
  amount      Decimal            @db.Decimal(12, 2)
  description String
  categoryId  String?
  frequency   RecurringFrequency
  startDate   DateTime
  nextDate    DateTime
  endDate     DateTime?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("recurring_rules")
}
